#!/usr/bin/env python3
import os
import sys
import json
import urllib.request
import urllib.error
import readline
import subprocess
import threading
import time
import re

# Configurações iniciais
API_KEY = os.environ.get("OPENROUTER_API_KEY")
SESSION_FILE = "SESSION.md"
CONFIG_FILE = os.path.expanduser("~/.openrouter.cfg")
MODEL_CONFIG_FILE = os.path.expanduser("~/.openrouter_model.cfg")
DEFAULT_MODEL = "qwen/qwen3-coder:free"

FALLBACK_MODELS = [
    "meta-llama/llama-3.3-70b-instruct:free",
    "qwen/qwen3-next-80b-a3b-instruct:free",
    "openai/gpt-oss-120b:free",
    "mistralai/mistral-small-3.1-24b-instruct:free",
    "google/gemma-3-27b-it:free",
    "openrouter/free"
]

# Comandos que são considerados destrutivos e precisam confirmação extra
DESTRUCTIVE_COMMANDS = {
    'rm', 'rmdir', 'dd', 'mkfs', 'fdisk', 'parted', 
    'shred', 'wipefs', 'chmod', 'chown', 'kill', 'killall',
    'shutdown', 'reboot', 'halt', 'poweroff'
}

if not API_KEY:
    print("Erro: OPENROUTER_API_KEY não definida.")
    print("Configure com: export OPENROUTER_API_KEY='sua-chave-aqui'")
    sys.exit(1)

# Carrega a Whitelist de comandos permitidos
allowed_commands = set()
if os.path.exists(CONFIG_FILE):
    with open(CONFIG_FILE, "r", encoding="utf-8") as f:
        allowed_commands = set(line.strip() for line in f if line.strip())

# Carrega o modelo que funcionou anteriormente
def load_working_model():
    """Carrega o último modelo que funcionou com sucesso."""
    if os.path.exists(MODEL_CONFIG_FILE):
        try:
            with open(MODEL_CONFIG_FILE, "r", encoding="utf-8") as f:
                saved_model = f.read().strip()
                if saved_model:
                    return saved_model
        except:
            pass
    return DEFAULT_MODEL

def save_working_model(model):
    """Salva o modelo que está funcionando."""
    try:
        with open(MODEL_CONFIG_FILE, "w", encoding="utf-8") as f:
            f.write(model)
    except:
        pass

args = sys.argv[1:]
active_model = load_working_model()
initial_prompt = ""

if args:
    if "/" in args[0]:
        active_model = args[0]
        initial_prompt = " ".join(args[1:])
    else:
        initial_prompt = " ".join(args)

SYSTEM_PROMPT = """Você é um agente autônomo de administração Linux executando em um loop de automação.
Sua tarefa é resolver a solicitação do usuário passo a passo usando comandos de terminal.

FORMATO DE RESPOSTA OBRIGATÓRIO:

Retorne APENAS UM comando por vez em formato JSON válido:

{
  "command": "comando bash aqui",
  "explanation": "breve explicação do que o comando faz",
  "reason": "por que este passo é necessário"
}

Quando a tarefa estiver 100% concluída, retorne:

{
  "status": "SUMMARY",
  "message": "Explicação detalhada do que foi feito e resultados finais"
}

REGRAS ESTRITAS:
1. APENAS um comando por resposta
2. SEMPRE em formato JSON válido
3. NÃO use markdown (sem ```json ou ```)
4. NÃO adicione texto antes ou depois do JSON
5. Para comandos complexos, use pipelines em uma única linha
6. O sistema executará o comando e retornará o output (stdout/stderr)
7. Analise o output devolvido antes de enviar o próximo comando
8. Se um comando falhar, analise o erro e tente uma alternativa
9. Seja eficiente: use comandos que retornem resultados diretos

IMPORTANTE:
- Um comando = uma resposta JSON
- Aguarde o output antes de decidir o próximo passo
- Quando completar o objetivo, envie o JSON com status "SUMMARY"
"""

def load_session():
    messages = [{"role": "system", "content": SYSTEM_PROMPT}]
    if not os.path.exists(SESSION_FILE):
        return messages
    with open(SESSION_FILE, "r", encoding="utf-8") as f:
        content = f.read()
    blocks = content.split("\n### ")
    for block in blocks:
        if block.startswith("User:\n"):
            messages.append({"role": "user", "content": block.replace("User:\n", "", 1).strip()})
        elif block.startswith("Assistant:\n"):
            messages.append({"role": "assistant", "content": block.replace("Assistant:\n", "", 1).strip()})
    return messages

def save_to_session(role, content):
    with open(SESSION_FILE, "a", encoding="utf-8") as f:
        f.write(f"\n### {role.capitalize()}:\n{content}\n")

def call_openrouter(messages):
    global active_model
    url = "https://openrouter.ai/api/v1/chat/completions"
    headers = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json",
        "HTTP-Referer": "https://linux-cli-agent.local",
        "X-Title": "Linux Sysadmin Agent"
    }
    
    # PRIMEIRO: Tenta apenas o modelo ativo (que funcionou antes)
    data = {"model": active_model, "messages": messages}
    req = urllib.request.Request(url, headers=headers, data=json.dumps(data).encode("utf-8"))
    
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            result = json.loads(response.read().decode("utf-8"))
            save_working_model(active_model)
            return result["choices"][0]["message"]["content"], active_model
    except urllib.error.HTTPError as e:
        sys.stdout.write("\r\033[2K")
        try:
            error_body = e.read().decode("utf-8")
            error_data = json.loads(error_body)
            error_msg = error_data.get('error', {}).get('message', 'Erro desconhecido')
            print(f"\033[93m⚠ Modelo atual ({active_model}) falhou: {error_msg}\033[0m")
            print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
        except:
            print(f"\033[93m⚠ Modelo atual ({active_model}) falhou (HTTP {e.code})\033[0m")
            print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
    except urllib.error.URLError as e:
        sys.stdout.write("\r\033[2K")
        print(f"\033[93m⚠ Modelo atual ({active_model}): Erro de conexão - {str(e.reason)}\033[0m")
        print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
    except Exception as e:
        sys.stdout.write("\r\033[2K")
        print(f"\033[91m⚠ Modelo atual ({active_model}): {str(e)}\033[0m")
        print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
    
    # SEGUNDO: Se o modelo ativo falhou, tenta os fallbacks
    last_error = None
    for current_model in FALLBACK_MODELS:
        if current_model == active_model:
            continue
            
        data = {"model": current_model, "messages": messages}
        req = urllib.request.Request(url, headers=headers, data=json.dumps(data).encode("utf-8"))
        
        try:
            with urllib.request.urlopen(req, timeout=30) as response:
                result = json.loads(response.read().decode("utf-8"))
                active_model = current_model
                save_working_model(active_model)
                print(f"\033[92m✓ Novo modelo ativo salvo: {active_model}\033[0m")
                return result["choices"][0]["message"]["content"], current_model
        except urllib.error.HTTPError as e:
            try:
                error_body = e.read().decode("utf-8")
                error_data = json.loads(error_body)
                error_msg = error_data.get('error', {}).get('message', 'Erro desconhecido')
                print(f"\033[90m  ↳ {current_model}: {error_msg}\033[0m")
                last_error = f"{current_model}: {error_msg}"
            except:
                print(f"\033[90m  ↳ {current_model}: HTTP {e.code}\033[0m")
                last_error = f"{current_model}: HTTP {e.code}"
            continue
        except urllib.error.URLError as e:
            print(f"\033[90m  ↳ {current_model}: {str(e.reason)}\033[0m")
            last_error = f"{current_model}: {str(e.reason)}"
            continue
        except Exception as e:
            print(f"\033[90m  ↳ {current_model}: {str(e)}\033[0m")
            last_error = f"{current_model}: {str(e)}"
            continue
            
    return f"[Erro] Todos os modelos falharam. Último erro: {last_error}", None

def call_openrouter_with_spinner(messages):
    """Executa a chamada de API em uma thread separada para animar o spinner."""
    result_container = {}
    
    def worker():
        result_container['data'] = call_openrouter(messages)
        
    t = threading.Thread(target=worker)
    t.start()
    
    spinner = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏']
    idx = 0
    while t.is_alive():
        sys.stdout.write(f"\r\033[96m🤖 IA Pensando... {spinner[idx]}\033[0m")
        sys.stdout.flush()
        idx = (idx + 1) % len(spinner)
        time.sleep(0.1)
        
    t.join()
    sys.stdout.write("\r\033[2K")
    return result_container.get('data', ("[Erro Interno da Thread]", None))

def parse_json_response(response_text):
    """Extrai e parseia JSON da resposta, removendo markdown se necessário."""
    clean_text = response_text.strip()
    
    # Remove markdown code blocks se existirem
    if clean_text.startswith("```json"):
        clean_text = clean_text.split("```json", 1)[1].split("```", 1)[0].strip()
    elif clean_text.startswith("```"):
        clean_text = clean_text.split("```", 1)[1].split("```", 1)[0].strip()
    
    try:
        return json.loads(clean_text)
    except json.JSONDecodeError as e:
        # Tenta encontrar JSON no texto
        json_match = re.search(r'\{.*\}', clean_text, re.DOTALL)
        if json_match:
            try:
                return json.loads(json_match.group())
            except:
                pass
        return None

def is_destructive_command(command):
    """Verifica se o comando é potencialmente destrutivo."""
    base_cmd = command.split()[0] if command.strip() else ""
    
    # Verifica comando base
    if base_cmd in DESTRUCTIVE_COMMANDS:
        return True
    
    # Verifica padrões perigosos
    dangerous_patterns = [
        r'rm\s+-rf\s+/',
        r'chmod\s+777',
        r'chown\s+.*\s+/',
        r'dd\s+.*of=',
        r'>\s*/dev/',
        r'mkfs\.',
    ]
    
    for pattern in dangerous_patterns:
        if re.search(pattern, command):
            return True
    
    return False

def display_command(cmd_data, step_num=None, total_steps=None):
    """Exibe o comando formatado com explicação."""
    print(f"\n\033[96m{'='*60}\033[0m")
    
    if step_num and total_steps:
        print(f"\033[96m📍 Passo {step_num}/{total_steps}\033[0m")
    elif step_num:
        print(f"\033[96m📍 Passo {step_num}\033[0m")
    
    print(f"\033[92m💡 {cmd_data.get('explanation', 'Executando comando...')}\033[0m")
    
    if 'reason' in cmd_data and cmd_data['reason']:
        print(f"\033[90m❓ {cmd_data['reason']}\033[0m")
    
    print(f"\033[96m{'='*60}\033[0m")
    print(f"\n\033[93m┌─ Comando:\033[0m")
    print(f"\033[93m│ {cmd_data['command']}\033[0m")
    print(f"\033[93m└─\033[0m\n")

def display_output(output, success=True):
    """Mostra output do comando para o usuário."""
    icon = "✓" if success else "✗"
    color = "\033[92m" if success else "\033[91m"
    
    print(f"\n{color}┌─ Resultado: [{icon}]\033[0m")
    
    if not output.strip():
        print(f"{color}│ [Comando executado sem saída no terminal]\033[0m")
    else:
        # Limita output exibido a 50 linhas
        lines = output.split('\n')
        display_lines = lines[:50]
        
        for line in display_lines:
            print(f"{color}│ {line}\033[0m")
        
        if len(lines) > 50:
            remaining = len(lines) - 50
            print(f"{color}│ ... [{remaining} linhas restantes omitidas]\033[0m")
    
    print(f"{color}└─\033[0m\n")

def process_command(user_input):
    global active_model
    
    if user_input == "/clear":
        if os.path.exists(SESSION_FILE):
            os.remove(SESSION_FILE)
        print("\033[92m✓ Sessão limpa. Histórico zerado.\033[0m")
        return "_clear_"
    elif user_input in ["/exit", "/quit"]:
        print("\n👋 Até logo!")
        sys.exit(0)
    elif user_input == "/help":
        print("\n\033[96m=== COMANDOS DISPONÍVEIS ===\033[0m")
        print("/clear      - Limpa o histórico da sessão")
        print("/exit       - Sai do programa")
        print("/help       - Mostra esta ajuda")
        print("/status     - Mostra status da sessão")
        print("/resetmodel - Reseta o modelo salvo para o padrão")
        print("\n\033[96m=== WHITELIST ===\033[0m")
        if allowed_commands:
            print(f"Comandos auto-permitidos: {', '.join(sorted(allowed_commands))}")
        else:
            print("Nenhum comando na whitelist ainda")
        print(f"Arquivo: {CONFIG_FILE}\n")
        return "_skip_"
    elif user_input == "/status":
        msg_count = len(load_session()) - 1
        model_source = "✓ salvo" if os.path.exists(MODEL_CONFIG_FILE) else "padrão"
        print(f"\n\033[96m=== STATUS ===\033[0m")
        print(f"Modelo ativo: {active_model} ({model_source})")
        print(f"Mensagens na sessão: {msg_count}")
        print(f"Comandos na whitelist: {len(allowed_commands)}")
        print(f"Arquivo de sessão: {SESSION_FILE}")
        print(f"Arquivo de modelo: {MODEL_CONFIG_FILE}\n")
        return "_skip_"
    elif user_input == "/resetmodel":
        if os.path.exists(MODEL_CONFIG_FILE):
            os.remove(MODEL_CONFIG_FILE)
        active_model = DEFAULT_MODEL
        print(f"\033[92m✓ Modelo resetado para o padrão: {DEFAULT_MODEL}\033[0m")
        print(f"\033[90m  (Na próxima chamada bem-sucedida, o novo modelo será salvo)\033[0m\n")
        return "_skip_"
    return user_input

def handle_turn(user_text):
    save_to_session("user", user_text)
    max_iterations = 30  # Aumentado para permitir mais passos
    iteration = 0
    
    while iteration < max_iterations:
        iteration += 1
        messages = load_session()
        
        response_content, successful_model = call_openrouter_with_spinner(messages)
        
        if not successful_model:
            print("\033[91m❌ Falha crítica na comunicação com a IA.\033[0m")
            print("\033[93mDica: Verifique sua conexão e se a API_KEY está correta.\033[0m")
            break

        # Parseia JSON
        cmd_data = parse_json_response(response_content)
        
        if not cmd_data:
            print("\033[91m❌ Erro: IA não retornou JSON válido.\033[0m")
            print(f"\033[90mResposta recebida:\033[0m\n{response_content[:500]}\n")
            save_to_session("assistant", response_content)
            save_to_session("user", "ERRO: Sua resposta não está em formato JSON válido. Corrija e retorne apenas o JSON conforme especificado no system prompt.")
            continue

        # Verifica se é SUMMARY (tarefa concluída)
        if cmd_data.get("status") == "SUMMARY":
            message = cmd_data.get("message", "Tarefa concluída.")
            print(f"\n\033[92m{'='*60}\033[0m")
            print(f"\033[92m✅ TAREFA CONCLUÍDA (via {successful_model})\033[0m")
            print(f"\033[92m{'='*60}\033[0m")
            print(f"\n{message}\n")
            print(f"\033[92m{'='*60}\033[0m\n")
            save_to_session("assistant", response_content)
            break
        
        # Verifica se tem comando
        if "command" not in cmd_data:
            print("\033[91m❌ Erro: JSON não contém campo 'command'.\033[0m")
            save_to_session("assistant", response_content)
            save_to_session("user", "ERRO: JSON deve conter o campo 'command'. Corrija e retorne o JSON correto.")
            continue
        
        command = cmd_data["command"].strip()
        
        if not command:
            print("\033[91m❌ Erro: Comando vazio.\033[0m")
            save_to_session("assistant", response_content)
            save_to_session("user", "ERRO: O campo 'command' está vazio. Forneça um comando válido.")
            continue
        
        # Exibe o comando
        display_command(cmd_data, iteration)
        
        # Pega o comando base para whitelist
        base_command = command.split()[0] if command else ""
        
        # Verifica se é comando destrutivo
        is_dangerous = is_destructive_command(command)
        
        # Decide sobre confirmação
        if base_command in allowed_commands:
            print(f"\033[92m✓ Auto-permitido: '{base_command}'\033[0m")
            confirm = 'enter'
        else:
            if is_dangerous:
                print(f"\033[91m⚠️  ATENÇÃO: Comando potencialmente DESTRUTIVO!\033[0m")
            
            print(f"\n\033[95m❓ Executar este comando?\033[0m")
            print(f"   [Enter] Sim  |  [n] Não  |  [a] Sempre permitir '{base_command}'")
            confirm = input("\033[95m➜ \033[0m").strip().lower()
        
        if confirm == 'n':
            print("\033[91m⚠ Comando abortado pelo usuário.\033[0m")
            save_to_session("assistant", response_content)
            save_to_session("user", "O usuário ABORTOU este comando. Forneça uma alternativa diferente ou, se não houver alternativa viável, finalize com status SUMMARY explicando que não foi possível completar a tarefa.")
            continue
        elif confirm == 'a':
            allowed_commands.add(base_command)
            with open(CONFIG_FILE, "a", encoding="utf-8") as f:
                f.write(base_command + "\n")
            print(f"\033[92m✓ '{base_command}' adicionado à whitelist permanente.\033[0m")
        
        print("\n\033[90m⚙ Executando...\033[0m")
        
        # Executa o comando
        try:
            result = subprocess.run(
                command, 
                shell=True, 
                text=True, 
                capture_output=True,
                executable='/bin/bash',
                timeout=120  # Timeout de 2 minutos
            )
            output = result.stdout + result.stderr
            success = result.returncode == 0
            
            if not output.strip():
                output = "[Comando executado com sucesso, sem saída no terminal]"
        except subprocess.TimeoutExpired:
            output = "[⚠ Timeout: Comando excedeu 120 segundos]"
            success = False
        except Exception as e:
            output = f"[❌ Erro de execução]: {str(e)}"
            success = False
        
        # Exibe output
        display_output(output, success)
        
        # Salva na sessão
        save_to_session("assistant", response_content)
        
        # Prepara feedback para a IA
        feedback = f"""Resultado da execução do comando:

COMANDO: {command}
STATUS: {'Sucesso (exit code 0)' if success else 'Falha (exit code não-zero)'}

OUTPUT:
{output}

Analise este resultado. Se precisar executar mais comandos para completar o objetivo, retorne o próximo comando em JSON. Se o objetivo inicial foi atingido, retorne JSON com status "SUMMARY" e uma explicação detalhada de tudo que foi feito."""
        
        save_to_session("user", feedback)
    
    if iteration >= max_iterations:
        print(f"\n\033[91m⚠ Limite de {max_iterations} iterações atingido. Encerrando.\033[0m\n")

def chat_loop(first_prompt=""):
    model_source = "💾 carregado do cache" if os.path.exists(MODEL_CONFIG_FILE) else "🆕 padrão"
    print("\033[96m" + "="*60 + "\033[0m")
    print("\033[96m🤖 OpenRouter AGENT - Assistente Linux Autônomo\033[0m")
    print("\033[96m" + "="*60 + "\033[0m")
    print(f"\033[90mModelo ativo:\033[0m {active_model} ({model_source})")
    print(f"\033[90mModo:\033[0m ⚡ Um comando por vez (JSON estruturado)")
    if allowed_commands:
        print(f"\033[90mWhitelist:\033[0m {len(allowed_commands)} comandos auto-permitidos")
    print(f"\033[90mComandos:\033[0m /help /clear /exit /status /resetmodel")
    print("\033[96m" + "="*60 + "\033[0m\n")
    
    if first_prompt:
        processed = process_command(first_prompt)
        if processed and processed not in ["_clear_", "_skip_"]:
            handle_turn(f"OBJETIVO: {processed}")
        
    while True:
        try:
            user_input = input("\033[92m💬 Você >\033[0m ").strip()
            if not user_input:
                continue
            
            processed_input = process_command(user_input)
            if processed_input in ["_clear_", "_skip_"]:
                continue
            elif processed_input is None:
                continue
                
            handle_turn(f"OBJETIVO: {processed_input}")
            
        except (KeyboardInterrupt, EOFError):
            print("\n\n👋 Saindo...")
            break

if __name__ == "__main__":
    chat_loop(initial_prompt)
