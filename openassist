                break
            elif choice == 't':
                print("\033[96m🔄 Tentando novamente...\033[0m")
                iteration -= 1  # Não conta esta iteração
                continue
            else:
                print("\033[91m✗ Opção inválida. Abortando.\033[0m")
                break
        
        if not successful_model:
