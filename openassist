def call_openrouter(messages):
    global active_model
    url = "https://openrouter.ai/api/v1/chat/completions"
    headers = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json",
        "HTTP-Referer": "https://linux-cli-agent.local",
        "X-Title": "Linux Sysadmin Agent"
    }
    
    # PRIMEIRO: Tenta apenas o modelo ativo (que funcionou antes)
    data = {"model": active_model, "messages": messages}
    req = urllib.request.Request(url, headers=headers, data=json.dumps(data).encode("utf-8"))
    
    try:
        with urllib.request.urlopen(req, timeout=USER_CONFIG['api_timeout']) as response:
            result = json.loads(response.read().decode("utf-8"))
            save_working_model(active_model)
            return result["choices"][0]["message"]["content"], active_model
    except urllib.error.HTTPError as e:
        sys.stdout.write("\r\033[2K")
        try:
            error_body = e.read().decode("utf-8")
            error_data = json.loads(error_body)
            error_msg = error_data.get('error', {}).get('message', 'Erro desconhecido')
            print(f"\033[93m⚠ Modelo atual ({active_model}) falhou: {error_msg}\033[0m")
            print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
        except:
            print(f"\033[93m⚠ Modelo atual ({active_model}) falhou (HTTP {e.code})\033[0m")
            print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
    except urllib.error.URLError as e:
        sys.stdout.write("\r\033[2K")
        print(f"\033[93m⚠ Modelo atual ({active_model}): Erro de conexão - {str(e.reason)}\033[0m")
        print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
    except Exception as e:
        sys.stdout.write("\r\033[2K")
        print(f"\033[91m⚠ Modelo atual ({active_model}): {str(e)}\033[0m")
        print(f"\033[96m🔄 Testando modelos alternativos...\033[0m")
    
    # SEGUNDO: Se o modelo ativo falhou, tenta os fallbacks
    last_error = None
    for current_model in FALLBACK_MODELS:
        if current_model == active_model:
            continue
            
        data = {"model": current_model, "messages": messages}
        req = urllib.request.Request(url, headers=headers, data=json.dumps(data).encode("utf-8"))
        
        try:
            with urllib.request.urlopen(req, timeout=USER_CONFIG['api_timeout']) as response:
                result = json.loads(response.read().decode("utf-8"))
                active_model = current_model
                save_working_model(active_model)
                print(f"\033[92m✓ Novo modelo ativo salvo: {active_model}\033[0m")
                return result["choices"][0]["message"]["content"], current_model
        except urllib.error.HTTPError as e:
            try:
                error_body = e.read().decode("utf-8")
                error_data = json.loads(error_body)
                error_msg = error_data.get('error', {}).get('message', 'Erro desconhecido')
                print(f"\033[90m  ↳ {current_model}: {error_msg}\033[0m")
                last_error = f"{current_model}: {error_msg}"
            except:
                print(f"\033[90m  ↳ {current_model}: HTTP {e.code}\033[0m")
                last_error = f"{current_model}: HTTP {e.code}"
            continue
        except urllib.error.URLError as e:
            print(f"\033[90m  ↳ {current_model}: {str(e.reason)}\033[0m")
            last_error = f"{current_model}: {str(e.reason)}"
            continue
        except Exception as e:
            print(f"\033[90m  ↳ {current_model}: {str(e)}\033[0m")
            last_error = f"{current_model}: {str(e)}"
            continue
            
    return f"[Erro] Todos os modelos falharam. Último erro: {last_error}", None

def format_elapsed_time(seconds):
    """Formata tempo decorrido em formato legível."""
    if seconds < 60:
        return f"{int(seconds)}s"
    elif seconds < 3600:
        mins = int(seconds // 60)
        secs = int(seconds % 60)
        return f"{mins}m {secs}s"
    else:
        hours = int(seconds // 3600)
        mins = int((seconds % 3600) // 60)
        return f"{hours}h {mins}m"

class KeyboardInterruptHandler:
    """Handler para capturar Ctrl+C sem quebrar o programa."""
    def __init__(self):
        self.interrupted = False
    
    def __enter__(self):
        self.interrupted = False
        self.old_handler = signal.signal(signal.SIGINT, self.handler)
        return self
    
    def handler(self, signum, frame):
        self.interrupted = True
    
    def __exit__(self, type, value, traceback):
        signal.signal(signal.SIGINT, self.old_handler)

def check_for_interrupt():
    """Verifica se Ctrl+C foi pressionado (mais confiável que ESC)."""
    # Usa método alternativo: verificação de stdin com timeout zero
    if sys.platform != 'win32':
        try:
            # Salva configurações atuais do terminal
            old_settings = termios.tcgetattr(sys.stdin)
            try:
                # Coloca em modo cbreak (lê caracteres sem esperar Enter)
                tty.setcbreak(sys.stdin.fileno())
                # Verifica se há input disponível (não bloqueia)
                dr, dw, de = select.select([sys.stdin], [], [], 0)
                if dr:
                    # Lê o caractere
                    c = sys.stdin.read(1)
                    # Ctrl+C = \x03, ESC = \x1b
                    if c in ['\x03', '\x1b']:
                        return True
            finally:
                # Restaura configurações do terminal
                termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_settings)
        except Exception:
            pass
    return False

def call_openrouter_with_spinner(messages):
    """Executa a chamada de API em uma thread separada com timer e detecção de interrupção."""
    result_container = {'data': None, 'aborted': False}
    start_time = time.time()
    
    def worker():
        try:
            result_container['data'] = call_openrouter(messages)
        except Exception as e:
            result_container['data'] = (f"[Erro na thread]: {str(e)}", None)
        
    t = threading.Thread(target=worker, daemon=True)
    t.start()
    
    spinner = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏']
    idx = 0
    
    print("\033[90m(Pressione Ctrl+C para cancelar)\033[0m")
    
    with KeyboardInterruptHandler() as h:
        while t.is_alive():
            elapsed = time.time() - start_time
            elapsed_str = format_elapsed_time(elapsed)
            
            sys.stdout.write(f"\r\033[96m🤖 IA Pensando... {spinner[idx]} ({elapsed_str})\033[0m")
            sys.stdout.flush()
            idx = (idx + 1) % len(spinner)
            
            # Verifica interrupção via handler
            if h.interrupted or check_for_interrupt():
                sys.stdout.write("\r\033[2K")
                print("\033[93m⚠ Cancelamento solicitado...\033[0m")
                result_container['aborted'] = True
                # Aguarda thread terminar com timeout
                t.join(timeout=3)
                break
            
            time.sleep(0.1)
    
    sys.stdout.write("\r\033[2K")
    
    if result_container['aborted']:
        return None, None, True  # data, model, aborted
    
    if result_container['data']:
        return result_container['data'][0], result_container['data'][1], False
    
    return "[Erro Interno da Thread]", None, False

def parse_json_response(response_text):
    """Extrai e parseia JSON da resposta, removendo markdown se necessário."""
    clean_text = response_text.strip()
    
    # Remove markdown code blocks se existirem
    if clean_text.startswith("```json"):
        clean_text = clean_text.split("```json", 1)[1].split("```", 1)[0].strip()
    elif clean_text.startswith("```"):
        clean_text = clean_text.split("```", 1)[1].split("```", 1)[0].strip()
    
    # Detecta múltiplos JSONs (erro comum)
    json_count = clean_text.count('{"')
    if json_count > 1:
        print(f"\033[91m⚠ Detectados {json_count} objetos JSON na resposta!\033[0m")
        print(f"\033[93m   A IA deve retornar APENAS UM JSON por vez.\033[0m")
        return None
    
    try:
        return json.loads(clean_text)
    except json.JSONDecodeError as e:
        # Tenta encontrar JSON no texto
        json_match = re.search(r'\{[^}]*"command"[^}]*\}|\{[^}]*"status"[^}]*\}', clean_text, re.DOTALL)
        if json_match:
            try:
                return json.loads(json_match.group())
            except:
                pass
        return None

def extract_all_base_commands(command):
    """Extrai todos os comandos base de um comando encadeado (com &&, ||, ;, |)."""
    # Separa por operadores de encadeamento
    separators = [' && ', ' || ', ' ; ', ' | ']
    
    # Substitui temporariamente para split único
    temp_command = command
    for sep in separators:
        temp_command = temp_command.replace(sep, '|||')
    
    # Split e extrai comando base de cada parte
    parts = temp_command.split('|||')
    base_commands = []
    
    for part in parts:
        part = part.strip()
        if part:
            # Pega primeiro comando (antes de espaço ou operador)
            base_cmd = part.split()[0] if part.split() else ""
            if base_cmd and base_cmd not in base_commands:
                base_commands.append(base_cmd)
    
    return base_commands

def check_all_commands_whitelisted(command, allowed_commands):
    """Verifica se TODOS os comandos do encadeamento estão na whitelist."""
    base_commands = extract_all_base_commands(command)
    not_whitelisted = [cmd for cmd in base_commands if cmd not in allowed_commands]
    return base_commands, not_whitelisted

def is_destructive_command(command):
    """Verifica se o comando é potencialmente destrutivo."""
    base_cmd = command.split()[0] if command.strip() else ""
    
    # Verifica comando base
    if base_cmd in DESTRUCTIVE_COMMANDS:
        return True
    
    # Verifica padrões perigosos
    dangerous_patterns = [
        r'rm\s+-rf\s+/',
        r'chmod\s+777',
        r'chown\s+.*\s+/',
        r'dd\s+.*of=',
        r'>\s*/dev/',
        r'mkfs\.',
    ]
    
    for pattern in dangerous_patterns:
        if re.search(pattern, command):
            return True
    
    return False

def is_interactive_command(command):
    """Verifica se o comando é interativo e não deve ser usado."""
    base_cmd = command.split()[0] if command.strip() else ""
    
    # Verifica comando base
    if base_cmd in INTERACTIVE_COMMANDS:
        return True
    
    # Verifica padrões interativos
    interactive_patterns = [
        r'^(python|python3|node|irb|php)\s*$',  # Sem argumentos = REPL interativo
        r'^(mysql|psql|mongo|redis-cli)\s+(-u|-h)?',  # CLIs de banco
    ]
    
    for pattern in interactive_patterns:
        if re.match(pattern, command.strip()):
            return True
    
    return False

def suggest_alternative_command(command):
    """Sugere alternativa não-interativa para comandos interativos."""
    base_cmd = command.split()[0] if command.strip() else ""
    
    alternatives = {
        'nano': 'echo "conteúdo" > arquivo.txt  OU  cat > arquivo.txt << EOF',
        'vim': 'echo "conteúdo" > arquivo.txt  OU  sed -i "s/antigo/novo/" arquivo.txt',
        'vi': 'echo "conteúdo" > arquivo.txt  OU  tee arquivo.txt',
        'less': 'cat arquivo.txt  OU  head/tail arquivo.txt',
        'more': 'cat arquivo.txt  OU  head -n 50 arquivo.txt',
        'top': 'ps aux --sort=-%cpu | head -n 20',
        'htop': 'ps aux --sort=-%cpu | head -n 20',
    }
    
    return alternatives.get(base_cmd, "Use comandos não-interativos (cat, echo, sed, awk, grep, etc)")

