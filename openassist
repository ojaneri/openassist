                print("\033[93mA tarefa anterior foi concluída.\033[0m")
                user_input = input("\033[92m💬 Novo objetivo >\033[0m ").strip()
                if user_input:
                    handle_turn(f"OBJETIVO: {user_input}")
            else:
                # Continua automaticamente
                handle_turn("Continue de onde parou. Analise o último resultado e prossiga com o próximo comando necessário para completar o objetivo original.")
        else:
            print("\033[91m✗ Opção inválida. Começando nova sessão.\033[0m\n")
            if os.path.exists(SESSION_FILE):
                os.remove(SESSION_FILE)
    
    if first_prompt:
        processed = process_command(first_prompt)
        if processed and processed not in ["_clear_", "_skip_"]:
            handle_turn(f"OBJETIVO: {processed}")
        
    while True:
        try:
            user_input = read_input_with_paste_detection()
            
            if user_input is None:  # EOFError
                print("\n\n👋 Saindo...")
                break
            
            if not user_input:
                continue
            
            processed_input = process_command(user_input)
            if processed_input in ["_clear_", "_skip_"]:
                continue
            elif processed_input is None:
                continue
                
            handle_turn(f"OBJETIVO: {processed_input}")
            
        except KeyboardInterrupt:
            print("\n\n👋 Saindo...")
            break

if __name__ == "__main__":
    chat_loop(initial_prompt)
