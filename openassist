def detect_paste(text):
    """Detecta se o texto foi colado (múltiplas linhas ou muito longo)."""
    lines = text.split('\n')
    is_paste = len(lines) > 1 or len(text) > 200
    return is_paste, len(lines)

def enable_paste_mode():
    """Habilita modo de paste no readline para permitir colar múltiplas linhas."""
    try:
        # Habilita bracketed paste mode no readline
        # Isso permite que o terminal detecte quando texto é colado
        readline.parse_and_bind('set enable-bracketed-paste on')
    except:
        pass

def read_multiline_paste():
    """Lê múltiplas linhas se paste for detectado."""
    lines = []
    first_line = input("\033[92m💬 Você >\033[0m ")
    
    # Se primeira linha está vazia ou é muito curta, retorna direto
    if not first_line or len(first_line) < 10:
        return first_line.strip()
    
    lines.append(first_line)
    
    # Tenta ler mais linhas se houver (modo paste)
    try:
        # Configura timeout muito curto para detectar paste
        import sys
        if sys.platform != 'win32':
            old_settings = termios.tcgetattr(sys.stdin)
            try:
                tty.setcbreak(sys.stdin.fileno())
                
                # Lê caracteres adicionais rapidamente (paste mode)
                additional_text = ""
                while True:
                    dr, dw, de = select.select([sys.stdin], [], [], 0.05)  # 50ms timeout
                    if not dr:
                        break
                    chunk = sys.stdin.read(1)
                    if not chunk:
                        break
                    additional_text += chunk
                    
                if additional_text:
                    lines.append(additional_text)
            finally:
                termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_settings)
    except:
        pass
    
    return '\n'.join(lines).strip()

def read_input_with_paste_detection():
    """Lê input do usuário com detecção de paste."""
    try:
        user_input = read_multiline_paste()
        
        if not user_input:
            return ""
        
        # Detecta se foi paste
        is_paste, line_count = detect_paste(user_input)
        
        if is_paste:
            # Mostra feedback de paste
            char_count = len(user_input)
            print(f"\n\033[96m📋 Conteúdo colado: {line_count} linhas, {char_count:,} caracteres\033[0m")
            
            # Mostra preview (primeiras 5 linhas)
            lines = user_input.split('\n')
            preview_lines = lines[:5]
            
            print(f"\033[90m┌─ Preview:\033[0m")
            for i, line in enumerate(preview_lines, 1):
                display_line = line[:100] + "..." if len(line) > 100 else line
                print(f"\033[90m│ L{i}: {display_line}\033[0m")
            
            if len(lines) > 5:
                print(f"\033[90m│ ... (+{len(lines) - 5} linhas adicionais)\033[0m")
            print(f"\033[90m└─\033[0m\n")
        
        return user_input
    
    except EOFError:
        return None

