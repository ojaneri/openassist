def load_session():
    messages = [{"role": "system", "content": SYSTEM_PROMPT}]
    if not os.path.exists(SESSION_FILE):
        return messages
    with open(SESSION_FILE, "r", encoding="utf-8") as f:
        content = f.read()
    blocks = content.split("\n### ")
    for block in blocks:
        if block.startswith("User:\n"):
            messages.append({"role": "user", "content": block.replace("User:\n", "", 1).strip()})
        elif block.startswith("Assistant:\n"):
            messages.append({"role": "assistant", "content": block.replace("Assistant:\n", "", 1).strip()})
    
    # Gerencia limite de contexto
    messages = manage_context_window(messages)
    return messages

def estimate_tokens(text):
    """Estima número de tokens baseado em caracteres."""
    if text is None:
        return 0
    return len(text) // CHARS_PER_TOKEN

def get_total_tokens(messages):
    """Calcula total de tokens em todas as mensagens."""
    total = 0
    for msg in messages:
        total += estimate_tokens(msg["content"])
    return total

def compress_message(content):
    """Compacta uma mensagem removendo redundâncias."""
    # Remove múltiplas linhas vazias
    content = re.sub(r'\n\n+', '\n\n', content)
    
    # Se for output muito longo, resume
    if "OUTPUT:" in content and len(content) > 5000:
        parts = content.split("OUTPUT:")
        if len(parts) == 2:
            header = parts[0]
            output = parts[1]
            
            # Pega primeiras e últimas linhas do output
            lines = output.strip().split('\n')
            if len(lines) > 20:
                compressed_output = '\n'.join(lines[:10]) + f'\n... [{len(lines) - 20} linhas omitidas] ...\n' + '\n'.join(lines[-10:])
                content = header + "OUTPUT:\n" + compressed_output
    
    return content

def manage_context_window(messages):
    """Gerencia limite de contexto: compacta ou trunca mensagens antigas."""
    total_tokens = get_total_tokens(messages)
    
    # Se está dentro do limite, retorna como está
    if total_tokens <= MAX_CONTEXT_TOKENS:
        return messages
    
    print(f"\033[93m⚠ Contexto grande ({total_tokens} tokens). Compactando...\033[0m")
    
    # Estratégia 1: Compactar mensagens antigas
    system_msg = messages[0]
    user_assistant_msgs = messages[1:]
    
    compressed_msgs = [system_msg]
    for msg in user_assistant_msgs:
        compressed_content = compress_message(msg["content"])
        compressed_msgs.append({"role": msg["role"], "content": compressed_content})
    
    total_tokens = get_total_tokens(compressed_msgs)
    
    # Se ainda está grande, trunca mantendo as mais recentes
    if total_tokens > MAX_CONTEXT_TOKENS:
        print(f"\033[93m⚠ Ainda grande ({total_tokens} tokens). Truncando para mensagens recentes...\033[0m")
        
        # Mantém system prompt + últimas N mensagens
        system_msg = compressed_msgs[0]
        recent_msgs = []
        current_tokens = estimate_tokens(system_msg["content"])
        
        # Adiciona mensagens de trás para frente até atingir limite
        for msg in reversed(compressed_msgs[1:]):
            msg_tokens = estimate_tokens(msg["content"])
            if current_tokens + msg_tokens > MAX_CONTEXT_TOKENS:
                break
            recent_msgs.insert(0, msg)
            current_tokens += msg_tokens
        
        truncated_msgs = [system_msg] + recent_msgs
        
        print(f"\033[92m✓ Contexto truncado: {len(truncated_msgs)} mensagens ({current_tokens} tokens)\033[0m")
        return truncated_msgs
    
    print(f"\033[92m✓ Contexto compactado: {total_tokens} tokens\033[0m")
    return compressed_msgs

def get_session_summary():
    """Gera resumo da sessão atual."""
    if not os.path.exists(SESSION_FILE):
        return None
    
    messages = []
    with open(SESSION_FILE, "r", encoding="utf-8") as f:
        content = f.read()
    blocks = content.split("\n### ")
    
    commands_executed = []
    last_objective = None
    last_summary = None
    
    for block in blocks:
        if block.startswith("User:\n"):
            user_content = block.replace("User:\n", "", 1).strip()
            if user_content.startswith("OBJETIVO:"):
                last_objective = user_content.replace("OBJETIVO:", "").strip()
        elif block.startswith("Assistant:\n"):
            assistant_content = block.replace("Assistant:\n", "", 1).strip()
            
            # Tenta parsear JSON
            try:
                data = json.loads(assistant_content)
                if "command" in data:
                    commands_executed.append(data["command"])
                elif "status" in data and data["status"] == "SUMMARY":
                    last_summary = data.get("message", "")
            except:
                pass
    
    if not last_objective and not commands_executed:
        return None
    
    summary = {
        "objective": last_objective,
        "commands_count": len(commands_executed),
        "last_commands": commands_executed[-3:] if len(commands_executed) > 0 else [],
        "completed": last_summary is not None,
        "summary": last_summary
    }
    
    return summary

