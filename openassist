    print(f"\033[96m🎯 NOVA TAREFA INICIADA\033[0m")
    print(f"\033[96m{'━'*60}\033[0m\n")
    
    save_to_session("user", user_text)
    max_iterations = USER_CONFIG['max_iterations']
    iteration = 0
    
    # Rastreamento de métricas (resetado a cada nova tarefa via handle_turn)
    task_start_time = time.time()
    total_api_calls = 0
    estimated_tokens_used = 0
    commands_executed = 0  # Contador separado de comandos realmente executados
    
    while iteration < max_iterations:
        iteration += 1
        messages = load_session()
        
        response_content, successful_model, aborted = call_openrouter_with_spinner(messages)
        
        # Incrementa contador de API calls
        if not aborted and successful_model:
            total_api_calls += 1
            # Estima tokens usados (request + response)
            request_tokens = get_total_tokens(messages)
            response_tokens = estimate_tokens(response_content) if response_content else 0
            estimated_tokens_used += request_tokens + response_tokens
        
        # Verifica se foi abortado via Ctrl+C
        if aborted:
            print("\n\033[93m⚠ Operação cancelada pelo usuário.\033[0m")
